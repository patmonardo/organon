    "block_type": "versetext",
    "record_kind": "sutra",
    "source_block_class": "versetext",
    "text": "स य एतदेवं विद्वान्साधु सामेत्युपास्तेऽभ्याशो ह यदेनꣳ साधवो धर्मा आ च गच्छेयुरुप च नमेयुः ॥ ४ ॥",
    "citations": []
  }
