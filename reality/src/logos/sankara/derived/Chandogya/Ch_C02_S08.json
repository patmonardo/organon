    "block_type": "versetext",
    "record_kind": "sutra",
    "source_block_class": "versetext",
    "text": "अथ सप्तविधस्य वाचि सप्तविधꣳ सामोपासीत यत्किञ्च वाचो हुमिति स हिङ्कारो युत्प्रेति स प्रस्तावो यदेति स आदिः ॥ १ ॥",
    "citations": []
  },
