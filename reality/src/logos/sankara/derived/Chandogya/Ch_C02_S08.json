    "block_type": "versetext",
    "record_kind": "sutra",
    "source_block_class": "versetext",
    "text": "यदुदिति स उद्गीथो यत्प्रतीति स प्रतिहारो यदुपेति स उपद्रवो यन्नीति तन्निधनम् ॥ २ ॥",
    "citations": []
