    "block_id": "Ch_C02_S24_V14_VERSETEXT_01",
    "block_type": "versetext",
    "text": "अथ जुहोति नम आदित्येभ्यश्च विश्वेभ्यश्च देवेभ्यो दिविक्षिद्भ्यो लोकक्षिद्भ्यो लोकं मे यजमानाय विन्दत ॥ १४ ॥",
    "citations": []
  },
  {
    "text_name": "Chandogya",
    "source_url": "https://advaitasharada.sringeri.net/display/bhashya",
    "source_sha256": "92ff589da76db5fc6138ac7bbbece4e460e491fbd7b0702954bf39e45a308e08",
    "text_id": "Ch",
