    "block_type": "bhashya",
    "record_kind": "bhasya",
    "source_block_class": "bhashya",
    "text": "अथ यद्द्वितीयममृतं तद्रुद्रा उपजीवन्तीत्यादि समानम् ॥",
    "citations": []
  },
  {
    "text_name": "Chandogya",
