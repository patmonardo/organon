    "verse_id": "Ch_C03_S07_V03",
    "block_id": "Ch_C03_S07_V03_VERSETEXT_01",
    "block_type": "versetext",
    "record_kind": "sutra",
    "source_block_class": "versetext",
    "text": "स य एतदेवममृतं वेद रुद्राणामेवैको भूत्वेन्द्रेणैव मुखेनैतदेवामृतं दृष्ट्वा तृप्यति स एतदेव रूपमभिसंविशत्येतस्माद्रूपादुदेति ॥ ३ ॥",
    "citations": []
  },
  {
    "text_name": "Chandogya",
