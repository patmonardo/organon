    "block_type": "versetext",
    "record_kind": "sutra",
    "source_block_class": "versetext",
    "text": "त एतदेव रूपमभिसंविशन्त्येतस्माद्रूपादुद्यन्ति ॥ २ ॥",
    "citations": []
