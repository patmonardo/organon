    "source_sha256": "da4b3f336a559abc83134e13ff041ac6cc2a8dc54a531b6b8153d2b6f7704b12",
    "text_id": "Ch",
    "chapter_id": "Ch_C04",
    "section_id": "Ch_C04_S08",
    "verse_id": "Ch_C04_S08_V01",
    "block_id": "Ch_C04_S08_V01_VERSETEXT_01",
    "block_type": "versetext",
    "record_kind": "sutra",
    "source_block_class": "versetext",
    "text": "मद्गुष्टे पादं वक्तेति स ह श्वोभूते गा अभिप्रस्थापयाञ्चकार ता यत्राभि सायं बभूवुस्तत्राग्निमुपसमाधाय गा उपरुध्य समिधमाधाय पश्चादग्नेः प्राङुपोपविवेश ॥ १ ॥",
    "citations": []
  },
  {
    "text_name": "Chandogya",
    "source_url": "https://advaitasharada.sringeri.net/display/bhashya",
    "source_sha256": "da4b3f336a559abc83134e13ff041ac6cc2a8dc54a531b6b8153d2b6f7704b12",
