    "source_sha256": "da4b3f336a559abc83134e13ff041ac6cc2a8dc54a531b6b8153d2b6f7704b12",
    "text_id": "Ch",
    "chapter_id": "Ch_C04",
    "section_id": "Ch_C04_S08",
    "verse_id": "Ch_C04_S08_V04",
    "block_id": "Ch_C04_S08_V04_B01",
    "block_type": "bhashya",
    "record_kind": "bhasya",
    "source_block_class": "bhashya",
    "text": "तं पादं तथैवोपास्ते यः स आयतनवान् आश्रयवानस्मिंल्लोके भवति । आयतनवत एव सावकाशांल्लोकान्मृतो जयति । य एतमेवमित्यादि पूर्ववत् ॥",
    "citations": []
  },
