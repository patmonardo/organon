    "block_type": "versetext",
    "record_kind": "sutra",
    "source_block_class": "versetext",
    "text": "प्राप हाचार्यकुलं तमाचार्योऽभ्युवाद सत्यकाम३ इति भगव इति ह प्रतिशुश्राव ॥ १ ॥",
    "citations": []
  },
  {
    "text_name": "Chandogya",
