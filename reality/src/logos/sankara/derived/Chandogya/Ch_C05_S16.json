    "source_sha256": "5497f4e368c2d64a01a45030b687d842038cfa89397dd9e8f4e2f6b2613c5633",
    "text_id": "Ch",
    "chapter_id": "Ch_C05",
    "section_id": "Ch_C05_S16",
    "verse_id": "Ch_C05_S16_V01",
    "block_id": "Ch_C05_S16_V01_VERSETEXT_01",
    "block_type": "versetext",
    "record_kind": "sutra",
    "source_block_class": "versetext",
    "text": "अथ होवाच बुडिलमाश्वतराश्विं वैयाघ्रपद्य कं त्वमात्मानमुपास्स इत्यप एव भगवो राजन्निति होवाचैष वै रयिरात्मा वैश्वानरो यं त्वमात्मानमुपास्से तस्मात्त्वं रयिमान्पुष्टिमानसि ॥ १ ॥",
    "citations": []
  },
  {
    "text_name": "Chandogya",
