    "verse_id": "Ch_C08_S02_V06",
    "block_id": "Ch_C08_S02_V06_VERSETEXT_01",
    "block_type": "versetext",
    "text": "अथ यदि गन्धमाल्यलोककामो भवति सङ्कल्पादेवास्य गन्धमाल्ये समुत्तिष्ठतस्तेन गन्धमाल्यलोकेन सम्पन्नो महीयते ॥ ६ ॥",
    "citations": []
  },
  {
    "text_name": "Chandogya",
    "source_url": "https://advaitasharada.sringeri.net/display/bhashya",
    "source_sha256": "4783d1cefb17b1b0aaa549a53471a2fe3a7a7b6a52e03d3cfce61f61ec608138",
    "text_id": "Ch",
