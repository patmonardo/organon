    "section_id": "Ch_C08_S02",
    "verse_id": "Ch_C08_S02_V05",
    "block_id": "Ch_C08_S02_V05_VERSETEXT_01",
    "block_type": "versetext",
    "text": "अथ यदि सखिलोककामो भवति सङ्कल्पादेवास्य सखायः समुत्तिष्ठन्ति तेन सखिलोकेन सम्पन्नो महीयते ॥ ५ ॥",
    "citations": []
  },
  {
    "text_name": "Chandogya",
    "source_url": "https://advaitasharada.sringeri.net/display/bhashya",
    "source_sha256": "4783d1cefb17b1b0aaa549a53471a2fe3a7a7b6a52e03d3cfce61f61ec608138",
