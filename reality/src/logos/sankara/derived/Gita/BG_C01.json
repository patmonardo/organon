  {
    "source_url": "https://advaitasharada.sringeri.net/display/bhashya/Gita/devanagari",
    "source_sha256": "39423dfeb0807452ffd6c4a9af1cbd863264efccf834adf712c8b5aacd822912",
    "chapter_id": "BG_C01",
    "verse_id": "BG_C01_V45",
    "versetext": "अहो बत महत्पापं कर्तुं व्यवसिता वयम् । \nयद्राज्यसुखलोभेन हन्तुं स्वजनमुद्यताः ॥ ४५ ॥",
    "leading_bhashya": "",
    "bhashya_blocks": [],
    "source_block_types_present": [
      "versetext"
